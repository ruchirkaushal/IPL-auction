{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "outDir": "./dist",
    "ignoreDeprecations": "5.0",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true
  },
  "include": [
    "./**/*.ts",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "scan-duplicates.ts",
    "../shared/playerDuplicateDetectorExamples.ts"
  ]
}
